{
  "name": "propax-monorepo",
  "version": "1.0.0",
  "description": "Application Propax - Frontend React + Backend Node.js",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently --names \"CLIENT,SERVER\" --prefix-colors \"cyan,yellow\" \"npm run client\" \"npm run server\"",
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "start": "npm run dev",
    "build": "cd client && npm run build",
    "test": "cd client && npm test",
    "clean": "rimraf client/node_modules server/node_modules node_modules",
    "reset": "npm run clean && npm run install-all"
  },
  "keywords": [
    "react",
    "nodejs",
    "express",
    "mysql",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5"
  },
  "workspaces": [
    "client",
    "server"
  ]
}
