# ============================================================
# .env.example - Variables d'environnement Propax
# IMPORTANT : Copier ce fichier en .env et remplir les valeurs
#             Ne jamais versionner le fichier .env réel !
# ============================================================

# ── Environnement ─────────────────────────────────────────
NODE_ENV=production

# ── Base de données MySQL ─────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=propax
DB_USER=propax_user
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ── Backend API ───────────────────────────────────────────
PORT=5000

# ── Authentification JWT ──────────────────────────────────
# Générer une valeur aléatoire robuste, ex: openssl rand -hex 64
JWT_SECRET=change_me_with_a_long_random_secret

# ── Frontend (URL de l'API en production) ─────────────────
REACT_APP_API_URL=http://localhost/api
